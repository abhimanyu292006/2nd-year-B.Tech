class Student:
    def __init__(self, name, age):
        self.name = name
        self.__age = age   # private attribute

    def display(self):
        return f"Name: {self.name}, Age: {self.__age}"

    def set_age(self, age):
        if age > 0:
            self.__age = age
        else:
            print("Invalid age!")



OUTPUT
s = Student("Abhimanyu", 21)
print(s.display())       # Name: Abhimanyu, Age: 21
s.set_age(22)
print(s.display())       # Name: Abhimanyu, Age: 22
